# ─── Research Portal — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=postgres          # use "localhost" when running backend directly (no Docker)
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres      # change in production
DB_NAME=research_portal
DB_SSLMODE=disable

# Alternatively, provide a full DSN (takes precedence over the individual vars above):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/research_portal?sslmode=disable

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random string. Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# Comma-separated list of allowed CORS origins.
# Use * to allow all origins (development only).
CORS_ALLOWED_ORIGINS=*

# ── Seeded Admin Accounts ─────────────────────────────────────────────────────
# All admin/manager accounts are hardcoded in db/migrate.go and seeded
# automatically on first boot (only if the users table is empty).
#
# To add or change accounts:
#   1. Edit the defaultAdmins slice in db/migrate.go
#   2. Generate a new bcrypt hash:
#        go run genhash.go          (create a small helper — see README)
#        or: htpasswd -bnBC 10 "" password | tr -d ':\n'
#   3. Rebuild and restart: docker compose up --build
#
# Current accounts (seeded by default):
#
#   Role     Email                        Password
#   ──────   ─────────────────────────    ─────────────
#   manager  anshus24@iitk.ac.in          Anshu@7341
#   manager  antrikshs24@iitk.ac.in       Antriksh@8629
#   manager  ensri24@iitk.ac.in           Neha@5182
#   admin    rajc25@iitk.ac.in            de325ut

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Set this in frontend/.env.local so Next.js knows where the backend is.
# NEXT_PUBLIC_API_URL=http://localhost:5000
