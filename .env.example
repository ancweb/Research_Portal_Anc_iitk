# ─── Research Portal — Environment Variables ─────────────────────────────────
# Copy this file to .env for local development:
#   cp .env.example .env
#
# NEVER commit .env to version control.
#
# ── Production ────────────────────────────────────────────────────────────────
# Railway (backend + database):
#   Set all variables below in your Railway service dashboard under "Variables".
#   DATABASE_URL is automatically injected when a PostgreSQL service is linked.
#
# Vercel (frontend):
#   Set NEXT_PUBLIC_API_URL in the Vercel project dashboard under
#   Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local/Docker: used when DATABASE_URL is not set.
# Railway: set DATABASE_URL instead; Railway injects it automatically.
DATABASE_URL=                        # auto-set by Railway Postgres — leave blank locally
DB_HOST=localhost                    # use "postgres" when running via docker-compose
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres                 # change in production
DB_NAME=research_portal
DB_SSLMODE=disable                   # use "require" on Railway

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000                            # Railway overrides this automatically

# ── CORS ─────────────────────────────────────────────────────────────────────
# Development: * (allow all)
# Production:  your Vercel deployment URL, e.g. https://research-portal-iitk.vercel.app
CORS_ALLOWED_ORIGINS=*
