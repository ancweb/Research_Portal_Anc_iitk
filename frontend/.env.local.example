# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local for local development:
#   cp .env.local.example .env.local
#
# NEVER commit .env.local to version control.
#
# ── Production (Vercel) ───────────────────────────────────────────────────────
# Set NEXT_PUBLIC_API_URL in the Vercel dashboard:
#   Project → Settings → Environment Variables
#   Value: https://<your-railway-backend-service>.up.railway.app
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL used by all fetch() calls in the frontend.
# Local development (docker-compose or direct):
NEXT_PUBLIC_API_URL=http://localhost:5000

# Production — replace with your Railway backend public URL:
# NEXT_PUBLIC_API_URL=https://<your-service>.up.railway.app
